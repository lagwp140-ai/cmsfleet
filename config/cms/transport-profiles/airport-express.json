{
    "transport":  {
                      "mode":  "bus",
                      "serviceArea":  "airport-corridor",
                      "routeStrategy":  {
                                            "type":  "static-pattern",
                                            "fallbackDestination":  "Airport Terminal",
                                            "preferRealtimeTripUpdates":  false
                                        }
                  },
    "gps":  {
                "provider":  "vendor-http",
                "sourceType":  "http-poll",
                "endpoint":  "https://vendor.example.invalid/shuttle-gps",
                "pollIntervalMs":  7000,
                "freshnessThresholdSeconds":  45,
                "vehicleIdField":  "unitCode",
                "simulate":  false,
                "offlineThresholdSeconds":  135,
                "movementThresholdKph":  8
            },
    "gtfs":  {
                 "enabled":  true,
                 "agencyId":  "airport-shuttle",
                 "timezone":  "Europe/Kiev",
                 "staticFeedUrl":  "https://feeds.example.invalid/airport/gtfs.zip"
             }
}
