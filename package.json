{
  "name": "cmsfleet",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo skeleton for a bus CMS platform.",
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "npm": ">=10.0.0 <11.0.0"
  },
  "workspaces": [
    "backend/*",
    "frontend/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "config:validate": "npm --workspace @cmsfleet/config-runtime run validate",
    "deploy:linux": "bash ./scripts/deploy-linux.sh",
    "dev:api": "npm --workspace @cmsfleet/backend-api run dev",
    "dev:web": "npm --workspace @cmsfleet/frontend-web run dev",
    "dev:worker": "npm --workspace @cmsfleet/integration-worker run dev",
    "format": "npm run format --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test:ci",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:api": "npm run test:api --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "test:ci": "npm run test:unit && npm run test:api && npm run test:integration",
    "dev:start": "tsx scripts/dev-runner.ts",
    "dev:setup": "tsx scripts/dev-setup.ts",
    "dev:provision": "npm run dev:stack:up && npm run dev:db:migrate && npm run dev:seed",
    "dev:stack:up": "docker compose -f deploy/docker-compose.dev.yml up -d",
    "dev:stack:down": "docker compose -f deploy/docker-compose.dev.yml down",
    "dev:stack:logs": "docker compose -f deploy/docker-compose.dev.yml logs -f",
    "dev:db:migrate": "tsx scripts/run-db-migrations.ts up",
    "dev:seed": "tsx scripts/seed-local-dev.ts",
    "dev:gps:send": "tsx scripts/mock-gps-sender.ts",
    "dev:display:status": "tsx scripts/mock-display-console.ts status",
    "dev:display:watch": "tsx scripts/mock-display-console.ts watch",
    "dev:display:publish": "tsx scripts/mock-display-console.ts publish"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.13.4",
    "eslint": "^9.20.1",
    "prettier": "^3.5.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.24.1",
    "vitest": "^3.0.8",
    "dotenv": "^16.4.7",
    "pg": "^8.13.3"
  }
}

