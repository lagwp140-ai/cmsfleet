# Shared local development settings
NODE_ENV=development
APP_ENV=local

# Configuration selection
CMS_CONFIG_ENV=local
CMS_CONFIG_TENANT_PROFILE=demo-city
CMS_CONFIG_TRANSPORT_PROFILE=urban-bus
CMS_CONFIG_VEHICLE_PROFILE=standard-bus-12m
CMS_CONFIG_DEVICE_PROFILE=linux-signage-unit
CMS_CONFIG_DISPLAY_PROFILE=hanover-led-3line
CMS_CONFIG_OVERRIDES=overrides/local-simulator.json

# Typed runtime overrides
CMS_API_PORT=3000
CMS_API_TRUST_PROXY=false
CMS_WORKER_POLL_INTERVAL_MS=5000
CMS_LOG_LEVEL=debug
CMS_CORS_ORIGINS=http://localhost:5173
CMS_DATABASE_URL=postgres://cmsfleet:cmsfleet@localhost:5432/cmsfleet
CMS_RATE_LIMIT_ENABLED=true
CMS_RATE_LIMIT_GENERAL_MAX_REQUESTS=600
CMS_RATE_LIMIT_GENERAL_WINDOW_SECONDS=60
CMS_RATE_LIMIT_LOGIN_MAX_ATTEMPTS=10
CMS_RATE_LIMIT_LOGIN_WINDOW_SECONDS=300
CMS_RATE_LIMIT_MUTATION_MAX_REQUESTS=120
CMS_RATE_LIMIT_MUTATION_WINDOW_SECONDS=60

# Authentication
CMS_AUTH_SESSION_SECRET=replace-this-with-a-long-random-secret
CMS_AUTH_CSRF_SECRET=replace-this-with-a-second-long-random-secret
CMS_AUTH_COOKIE_NAME=cmsfleet_session
CMS_AUTH_SESSION_MAX_AGE_MINUTES=480
CMS_AUTH_SESSION_SAME_SITE=lax
CMS_AUTH_PASSWORD_MIN_LENGTH=12
CMS_AUTH_PASSWORD_MAX_LENGTH=128
CMS_AUTH_PASSWORD_ITERATIONS=210000
CMS_AUTH_PASSWORD_REQUIRE_LOWERCASE=true
CMS_AUTH_PASSWORD_REQUIRE_UPPERCASE=true
CMS_AUTH_PASSWORD_REQUIRE_NUMBER=true
CMS_AUTH_PASSWORD_REQUIRE_SYMBOL=true
CMS_AUTH_SECURE_COOKIES=false
CMS_AUTH_BOOTSTRAP_USERS_ENABLED=true
CMSFLEET_DEV_PASSWORD=Transit!Demo2026

# PostgreSQL
POSTGRES_DB=cmsfleet
POSTGRES_USER=cmsfleet
POSTGRES_PASSWORD=cmsfleet
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
ADMINER_PORT=8080

# Service URLs
CMSFLEET_API_BASE_URL=http://localhost:3000
CMSFLEET_WEB_BASE_URL=http://localhost:5173

# Deep override examples
# CMS_CFG__feature_flags__advanced_head_sign_rules=true
# CMS_CFG__branding__application_name=Kyiv Fleet CMS
